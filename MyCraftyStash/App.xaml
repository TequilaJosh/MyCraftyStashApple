<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:converters="clr-namespace:MyCraftyStash.Converters"
             x:Class="MyCraftyStash.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Converters -->
            <converters:IsNotNullConverter x:Key="IsNotNullConverter" />
            <converters:InvertedBoolConverter x:Key="InvertedBoolConverter" />
            <converters:ImageStringConverter x:Key="ImageStringConverter" />
            <converters:NavSelectedConverter x:Key="NavSelectedConverter" />
            <converters:StockLevelColorConverter x:Key="StockLevelColorConverter" />
            <converters:AllTrueConverter x:Key="AllTrueConverter" />
            <converters:IsZeroConverter x:Key="IsZeroConverter" />

            <!-- ── My Crafty Stash warm palette (matches the Windows app) ── -->
            <Color x:Key="StashPrimary">#A82C32</Color>
            <Color x:Key="StashBackground">#F2EEE6</Color>
            <Color x:Key="StashCard">#F6F2EB</Color>
            <Color x:Key="StashBorder">#E1DCD0</Color>
            <Color x:Key="StashText">#1E1B17</Color>
            <Color x:Key="StashTextMuted">#7A7264</Color>
            <Color x:Key="StashSidebar">#EBE6D9</Color>
            <Color x:Key="StashSidebarHover">#E0DAC9</Color>
            <Color x:Key="StashSidebarSelected">#F6F2EB</Color>
            <Color x:Key="ErrorRed">#D9534F</Color>

            <!-- Content pages use the warm background + dark text -->
            <Style TargetType="ContentPage" ApplyToDerivedTypes="True">
                <Setter Property="BackgroundColor" Value="{StaticResource StashBackground}" />
            </Style>

            <!-- Sidebar nav row: rounded, fills when selected -->
            <Style x:Key="NavRow" TargetType="Border">
                <Setter Property="StrokeThickness" Value="0" />
                <Setter Property="StrokeShape" Value="RoundRectangle 10" />
                <Setter Property="Padding" Value="12,10" />
                <Setter Property="Margin" Value="0,1" />
            </Style>
            <Style x:Key="NavIcon" TargetType="Label">
                <Setter Property="FontSize" Value="15" />
                <Setter Property="WidthRequest" Value="24" />
                <Setter Property="TextColor" Value="{StaticResource StashTextMuted}" />
                <Setter Property="VerticalOptions" Value="Center" />
            </Style>
            <Style x:Key="NavText" TargetType="Label">
                <Setter Property="FontSize" Value="14" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="TextColor" Value="{StaticResource StashText}" />
                <Setter Property="VerticalOptions" Value="Center" />
            </Style>
            <Style x:Key="NavSectionHeader" TargetType="Label">
                <Setter Property="FontSize" Value="11" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="TextColor" Value="{StaticResource StashTextMuted}" />
                <Setter Property="Margin" Value="12,18,0,6" />
            </Style>

            <!-- ── Shared content styles (match the desktop) ── -->
            <Color x:Key="StashSurface">#F6F2EB</Color>
            <Color x:Key="StashBadge">#E0DAC9</Color>
            <!-- Distinct fill for interactive inputs so they stand out from the
                 cream page/card background (white, like the desktop's fields). -->
            <Color x:Key="StashInput">#FFFFFF</Color>

            <!-- Implicit input styles: every Entry/Editor/Picker/DatePicker/
                 SearchBar gets a white fill + a soft border so they read as
                 editable, not as page background. Controls that set their own
                 BackgroundColor locally (e.g. the ones inside a coloured pill)
                 keep that value. -->
            <Style TargetType="Entry">
                <Setter Property="BackgroundColor" Value="{StaticResource StashInput}" />
                <Setter Property="TextColor" Value="{StaticResource StashText}" />
                <Setter Property="PlaceholderColor" Value="{StaticResource StashTextMuted}" />
            </Style>
            <Style TargetType="Editor">
                <Setter Property="BackgroundColor" Value="{StaticResource StashInput}" />
                <Setter Property="TextColor" Value="{StaticResource StashText}" />
                <Setter Property="PlaceholderColor" Value="{StaticResource StashTextMuted}" />
            </Style>
            <Style TargetType="Picker">
                <Setter Property="BackgroundColor" Value="{StaticResource StashInput}" />
                <Setter Property="TextColor" Value="{StaticResource StashText}" />
                <Setter Property="TitleColor" Value="{StaticResource StashTextMuted}" />
            </Style>
            <Style TargetType="DatePicker">
                <Setter Property="BackgroundColor" Value="{StaticResource StashInput}" />
                <Setter Property="TextColor" Value="{StaticResource StashText}" />
            </Style>
            <Style TargetType="TimePicker">
                <Setter Property="BackgroundColor" Value="{StaticResource StashInput}" />
                <Setter Property="TextColor" Value="{StaticResource StashText}" />
            </Style>
            <Style TargetType="SearchBar">
                <Setter Property="BackgroundColor" Value="{StaticResource StashInput}" />
                <Setter Property="TextColor" Value="{StaticResource StashText}" />
                <Setter Property="PlaceholderColor" Value="{StaticResource StashTextMuted}" />
            </Style>

            <!-- Page header: breadcrumb (12 muted) + title (28 bold) + subtitle (13 muted) -->
            <Style x:Key="Breadcrumb" TargetType="Label">
                <Setter Property="FontSize" Value="12" />
                <Setter Property="TextColor" Value="{StaticResource StashTextMuted}" />
            </Style>
            <Style x:Key="PageTitle" TargetType="Label">
                <Setter Property="FontSize" Value="28" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="TextColor" Value="{StaticResource StashText}" />
            </Style>
            <Style x:Key="PageSubtitle" TargetType="Label">
                <Setter Property="FontSize" Value="13" />
                <Setter Property="TextColor" Value="{StaticResource StashTextMuted}" />
                <Setter Property="Margin" Value="0,4,0,0" />
            </Style>
            <Style x:Key="SectionHeader" TargetType="Label">
                <Setter Property="FontSize" Value="16" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="TextColor" Value="{StaticResource StashText}" />
            </Style>
            <Style x:Key="FieldLabel" TargetType="Label">
                <Setter Property="FontSize" Value="12" />
                <Setter Property="TextColor" Value="{StaticResource StashTextMuted}" />
            </Style>

            <!-- Card: rounded bg card with 1px border (corner 12, pad 16) -->
            <Style x:Key="CardStyle" TargetType="Border">
                <Setter Property="BackgroundColor" Value="{StaticResource StashCard}" />
                <Setter Property="Stroke" Value="{StaticResource StashBorder}" />
                <Setter Property="StrokeThickness" Value="1" />
                <Setter Property="StrokeShape" Value="RoundRectangle 12" />
                <Setter Property="Padding" Value="16" />
            </Style>
            <!-- Panel/section card (corner 14, pad 20) -->
            <Style x:Key="PanelCard" TargetType="Border">
                <Setter Property="BackgroundColor" Value="{StaticResource StashSurface}" />
                <Setter Property="Stroke" Value="{StaticResource StashBorder}" />
                <Setter Property="StrokeThickness" Value="1" />
                <Setter Property="StrokeShape" Value="RoundRectangle 14" />
                <Setter Property="Padding" Value="20" />
            </Style>

            <!-- Buttons -->
            <Style x:Key="PrimaryButton" TargetType="Button">
                <Setter Property="BackgroundColor" Value="{StaticResource StashPrimary}" />
                <Setter Property="TextColor" Value="White" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="CornerRadius" Value="10" />
                <Setter Property="Padding" Value="16,8" />
            </Style>
            <Style x:Key="SecondaryButton" TargetType="Button">
                <Setter Property="BackgroundColor" Value="{StaticResource StashSidebar}" />
                <Setter Property="TextColor" Value="{StaticResource StashText}" />
                <Setter Property="CornerRadius" Value="10" />
                <Setter Property="Padding" Value="16,8" />
            </Style>
            <Style x:Key="DangerButton" TargetType="Button">
                <Setter Property="BackgroundColor" Value="{StaticResource ErrorRed}" />
                <Setter Property="TextColor" Value="White" />
                <Setter Property="CornerRadius" Value="10" />
                <Setter Property="Padding" Value="16,8" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
