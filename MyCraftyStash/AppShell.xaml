<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="MyCraftyStash.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:MyCraftyStash.Views"
    Title="My Crafty Stash">

    <!-- Sign-in first: App redirects to //inventory at startup when a stored
         key exists. The page itself disables the flyout. -->
    <ShellContent
        Title="Sign in"
        Route="signin"
        FlyoutItemIsVisible="False"
        ContentTemplate="{DataTemplate views:SignInPage}" />

    <FlyoutItem Title="Inventory">
        <ShellContent Route="inventory" ContentTemplate="{DataTemplate views:InventoryPage}" />
    </FlyoutItem>

    <FlyoutItem Title="Settings">
        <ShellContent Route="settings" ContentTemplate="{DataTemplate views:SettingsPage}" />
    </FlyoutItem>

</Shell>
