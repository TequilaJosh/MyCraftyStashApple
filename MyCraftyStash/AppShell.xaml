<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="MyCraftyStash.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:MyCraftyStash.Views"
    Title="My Crafty Stash">

    <FlyoutItem Title="Inventory">
        <ShellContent Route="inventory" ContentTemplate="{DataTemplate views:InventoryPage}" />
    </FlyoutItem>

    <FlyoutItem Title="Settings">
        <ShellContent Route="settings" ContentTemplate="{DataTemplate views:SettingsPage}" />
    </FlyoutItem>

</Shell>
