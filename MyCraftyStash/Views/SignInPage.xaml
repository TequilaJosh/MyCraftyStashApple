<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="MyCraftyStash.Views.SignInPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:MyCraftyStash.ViewModels"
             x:DataType="vm:SignInViewModel"
             Shell.FlyoutBehavior="Disabled"
             Shell.NavBarIsVisible="False"
             Title="Sign in">

    <VerticalStackLayout Spacing="16" VerticalOptions="Center" HorizontalOptions="Center" MaximumWidthRequest="420" Padding="32">
        <Label Text="📦" FontSize="56" HorizontalOptions="Center"/>
        <Label Text="My Crafty Stash" FontSize="32" FontAttributes="Bold" HorizontalOptions="Center"/>
        <Label Text="Paste an API key from the Windows app (Settings › Cloud Sync › API Keys) to browse your stash."
               HorizontalTextAlignment="Center"
               TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray300}}"/>

        <Entry Placeholder="mcs_…" IsPassword="True" Text="{Binding ApiKey}"/>

        <Label Text="{Binding ErrorMessage}"
               IsVisible="{Binding ErrorMessage, Converter={StaticResource IsNotNullConverter}}"
               TextColor="{StaticResource ErrorRed}"
               HorizontalTextAlignment="Center"/>

        <Button Text="Connect" Command="{Binding ConnectCommand}" IsEnabled="{Binding Busy, Converter={StaticResource InvertedBoolConverter}}"/>
        <ActivityIndicator IsRunning="{Binding Busy}" IsVisible="{Binding Busy}"/>
    </VerticalStackLayout>
</ContentPage>
