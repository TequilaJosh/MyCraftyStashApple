<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="MyCraftyStash.Views.ItemEditPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:MyCraftyStash.ViewModels"
             x:DataType="vm:ItemEditViewModel"
             Title="{Binding PageTitle}">

    <ScrollView>
        <VerticalStackLayout Spacing="14" Padding="20" MaximumWidthRequest="620">

            <Label Text="{Binding ErrorMessage}"
                   IsVisible="{Binding ErrorMessage, Converter={StaticResource IsNotNullConverter}}"
                   TextColor="{StaticResource ErrorRed}"/>

            <Label Text="Name *"/>
            <Entry Text="{Binding Name}" Placeholder="e.g. Stitched Rectangles"/>

            <Label Text="Type *"/>
            <Entry Text="{Binding Type}" Placeholder="e.g. Die, Stamp, Stencil"/>

            <Label Text="Theme"/>
            <Entry Text="{Binding Theme}"/>

            <Label Text="Item number"/>
            <Entry Text="{Binding ItemNumber}"/>

            <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                <VerticalStackLayout Grid.Column="0" Spacing="4">
                    <Label Text="Price"/>
                    <Entry Text="{Binding PriceText}" Keyboard="Numeric" Placeholder="0.00"/>
                </VerticalStackLayout>
                <VerticalStackLayout Grid.Column="1" Spacing="4">
                    <Label Text="Current stock"/>
                    <Entry Text="{Binding CurrentStockText}" Keyboard="Numeric"/>
                </VerticalStackLayout>
            </Grid>

            <Label Text="Location"/>
            <Entry Text="{Binding Location}"/>

            <Label Text="Purchased from"/>
            <Entry Text="{Binding PurchasedFrom}"/>

            <HorizontalStackLayout Spacing="10">
                <Switch IsToggled="{Binding IsDiscontinued}"/>
                <Label Text="Discontinued" VerticalOptions="Center"/>
            </HorizontalStackLayout>

            <Label Text="Notes"/>
            <Editor Text="{Binding Notes}" AutoSize="TextChanges" MinimumHeightRequest="90"/>

            <HorizontalStackLayout Spacing="12" Margin="0,10,0,0">
                <Button Text="Save" Command="{Binding SaveCommand}"/>
                <Button Text="Cancel" Command="{Binding CancelCommand}"
                        BackgroundColor="Transparent"
                        TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray300}}"/>
            </HorizontalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
