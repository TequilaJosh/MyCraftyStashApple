<?xml version="1.0" encoding="utf-8" ?>
<ContentView x:Class="MyCraftyStash.Views.ItemPickerView"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:MyCraftyStash.ViewModels"
             xmlns:models="clr-namespace:MyCraftyStash.Models"
             x:Name="Root"
             x:DataType="vm:ItemPickerViewModel">

    <Grid RowDefinitions="Auto,Auto,*">

        <Grid Grid.Row="0" ColumnDefinitions="Auto,*" Padding="20,16" ColumnSpacing="10">
            <Button Grid.Column="0" Text="‹ Back" Command="{Binding CancelCommand}"
                    BackgroundColor="Transparent" TextColor="{StaticResource StashText}"/>
            <Label Grid.Column="1" Text="Add an item" FontSize="22" FontAttributes="Bold"
                   TextColor="{StaticResource StashText}" VerticalOptions="Center"/>
        </Grid>

        <SearchBar Grid.Row="1" Placeholder="Search your inventory"
                   Text="{Binding SearchText}" SearchCommand="{Binding SearchCommand}"
                   Margin="20,0,20,6"/>

        <CollectionView Grid.Row="2" ItemsSource="{Binding Items}" SelectionMode="None" Margin="20,0">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Item">
                    <Border StrokeShape="RoundRectangle 10" StrokeThickness="0"
                            BackgroundColor="{StaticResource StashCard}" Padding="14,10" Margin="0,0,0,8">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding BindingContext.PickCommand, Source={x:Reference Root}, x:DataType=ContentView}"
                                                  CommandParameter="{Binding .}"/>
                        </Border.GestureRecognizers>
                        <Grid ColumnDefinitions="*,Auto">
                            <VerticalStackLayout Spacing="1" VerticalOptions="Center">
                                <Label Text="{Binding Name}" FontAttributes="Bold" FontSize="14" TextColor="{StaticResource StashText}"/>
                                <Label Text="{Binding Type}" FontSize="12" TextColor="{StaticResource StashTextMuted}"/>
                            </VerticalStackLayout>
                            <Label Grid.Column="1" Text="+ Add" TextColor="{StaticResource StashPrimary}"
                                   FontAttributes="Bold" VerticalOptions="Center"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
            <CollectionView.EmptyView>
                <VerticalStackLayout Spacing="10" VerticalOptions="Center" Padding="40">
                    <Label Text="No items to add" FontSize="18" FontAttributes="Bold"
                           HorizontalOptions="Center" TextColor="{StaticResource StashText}"/>
                    <Label Text="Every item is already linked, or your search has no matches."
                           HorizontalTextAlignment="Center" TextColor="{StaticResource StashTextMuted}"/>
                </VerticalStackLayout>
            </CollectionView.EmptyView>
        </CollectionView>
    </Grid>
</ContentView>
