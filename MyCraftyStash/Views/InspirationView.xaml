<?xml version="1.0" encoding="utf-8" ?>
<ContentView x:Class="MyCraftyStash.Views.InspirationView"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:MyCraftyStash.ViewModels"
             xmlns:models="clr-namespace:MyCraftyStash.Models"
             x:Name="Root"
             x:DataType="vm:InspirationViewModel">

    <Grid RowDefinitions="Auto,Auto,*">

        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Padding="24,18,24,10">
            <Label Text="Inspiration" FontSize="26" FontAttributes="Bold" TextColor="{StaticResource StashText}"/>
            <Button Grid.Column="1" Text="+ Add Photo" Command="{Binding AddImageCommand}"
                    BackgroundColor="{StaticResource StashPrimary}" TextColor="White"/>
        </Grid>

        <Label Grid.Row="1" Text="{Binding Error}" IsVisible="{Binding Error, Converter={StaticResource IsNotNullConverter}}"
               TextColor="{StaticResource ErrorRed}" Margin="24,0,24,6"/>

        <CollectionView Grid.Row="2" ItemsSource="{Binding Images}" SelectionMode="None" Margin="16,0">
            <CollectionView.ItemsLayout>
                <GridItemsLayout Orientation="Vertical" Span="3"
                                 HorizontalItemSpacing="12" VerticalItemSpacing="12"/>
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:InspirationImage">
                    <Border StrokeShape="RoundRectangle 12" StrokeThickness="0"
                            BackgroundColor="{StaticResource StashCard}" Padding="6">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding BindingContext.OpenImageCommand, Source={x:Reference Root}, x:DataType=ContentView}"
                                                  CommandParameter="{Binding .}"/>
                        </Border.GestureRecognizers>
                        <Image Source="{Binding ImageUrl, Converter={StaticResource ImageStringConverter}}"
                               Aspect="AspectFill" HeightRequest="160"/>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
            <CollectionView.EmptyView>
                <VerticalStackLayout Spacing="10" VerticalOptions="Center" Padding="40">
                    <Label Text="No inspiration yet" FontSize="20" FontAttributes="Bold"
                           HorizontalOptions="Center" TextColor="{StaticResource StashText}"/>
                    <Label Text="Tap Add Photo to save a picture that inspires your next make."
                           HorizontalTextAlignment="Center" TextColor="{StaticResource StashTextMuted}"/>
                </VerticalStackLayout>
            </CollectionView.EmptyView>
        </CollectionView>

        <ActivityIndicator Grid.Row="2" IsRunning="{Binding Busy}" IsVisible="{Binding Busy}"
                           VerticalOptions="Center" HorizontalOptions="Center"/>
    </Grid>
</ContentView>
