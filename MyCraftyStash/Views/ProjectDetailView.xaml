<?xml version="1.0" encoding="utf-8" ?>
<ContentView x:Class="MyCraftyStash.Views.ProjectDetailView"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:MyCraftyStash.ViewModels"
             xmlns:models="clr-namespace:MyCraftyStash.Models"
             x:Name="Root"
             x:DataType="vm:ProjectDetailViewModel">

    <Grid RowDefinitions="Auto,*">

        <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto,Auto" Padding="20,16" ColumnSpacing="10">
            <Button Grid.Column="0" Text="‹ Back" Command="{Binding BackCommand}"
                    BackgroundColor="Transparent" TextColor="{StaticResource StashText}"/>
            <Label Grid.Column="1" Text="{Binding Project.Name}" FontSize="22" FontAttributes="Bold"
                   TextColor="{StaticResource StashText}" VerticalOptions="Center" LineBreakMode="TailTruncation"/>
            <Button Grid.Column="2" Text="Edit" Command="{Binding EditCommand}"
                    BackgroundColor="{StaticResource StashPrimary}" TextColor="White"/>
            <Button Grid.Column="3" Text="Delete" Command="{Binding DeleteCommand}"
                    BackgroundColor="{StaticResource ErrorRed}" TextColor="White"/>
        </Grid>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="18" Padding="20" MaximumWidthRequest="760">

                <Border StrokeShape="RoundRectangle 12" StrokeThickness="0" BackgroundColor="White"
                        IsVisible="{Binding Project.ImageUrl, Converter={StaticResource IsNotNullConverter}}">
                    <Image Source="{Binding Project.ImageUrl, Converter={StaticResource ImageStringConverter}}"
                           Aspect="AspectFit" MaximumHeightRequest="360"/>
                </Border>

                <VerticalStackLayout Spacing="4" IsVisible="{Binding Project.Description, Converter={StaticResource IsNotNullConverter}}">
                    <Label Text="Description" FontAttributes="Bold" FontSize="16" TextColor="{StaticResource StashText}"/>
                    <Label Text="{Binding Project.Description}" TextColor="{StaticResource StashText}"/>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="4" IsVisible="{Binding Project.Technique, Converter={StaticResource IsNotNullConverter}}">
                    <Label Text="Technique" FontAttributes="Bold" FontSize="16" TextColor="{StaticResource StashText}"/>
                    <Label Text="{Binding Project.Technique}" TextColor="{StaticResource StashText}"/>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="4" IsVisible="{Binding Project.Notes, Converter={StaticResource IsNotNullConverter}}">
                    <Label Text="Notes" FontAttributes="Bold" FontSize="16" TextColor="{StaticResource StashText}"/>
                    <Label Text="{Binding Project.Notes}" TextColor="{StaticResource StashText}"/>
                </VerticalStackLayout>

                <!-- Items used -->
                <VerticalStackLayout Spacing="8">
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Text="Items used" FontAttributes="Bold" FontSize="16" TextColor="{StaticResource StashText}" VerticalOptions="Center"/>
                        <Button Grid.Column="1" Text="+ Add item" Command="{Binding AddItemLinkCommand}"
                                Padding="12,4" FontSize="13"
                                BackgroundColor="{StaticResource StashPrimary}" TextColor="White"/>
                    </Grid>
                    <Label Text="No supplies linked yet — tap Add item to link what you used."
                           IsVisible="{Binding HasItemsUsed, Converter={StaticResource InvertedBoolConverter}}"
                           TextColor="{StaticResource StashTextMuted}"/>
                    <VerticalStackLayout BindableLayout.ItemsSource="{Binding ItemsUsed}" Spacing="6">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="models:Item">
                                <Border StrokeShape="RoundRectangle 8" StrokeThickness="0"
                                        BackgroundColor="{StaticResource StashCard}" Padding="12,8">
                                    <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
                                        <VerticalStackLayout Spacing="0" VerticalOptions="Center">
                                            <VerticalStackLayout.GestureRecognizers>
                                                <TapGestureRecognizer Command="{Binding BindingContext.OpenItemCommand, Source={x:Reference Root}, x:DataType=ContentView}"
                                                                      CommandParameter="{Binding .}"/>
                                            </VerticalStackLayout.GestureRecognizers>
                                            <Label Text="{Binding Name}" TextColor="{StaticResource StashText}"/>
                                            <Label Text="{Binding Type}" FontSize="12" TextColor="{StaticResource StashTextMuted}"/>
                                        </VerticalStackLayout>
                                        <Label Grid.Column="2" Text="✕" FontSize="16" VerticalOptions="Center"
                                               TextColor="{StaticResource StashTextMuted}">
                                            <Label.GestureRecognizers>
                                                <TapGestureRecognizer Command="{Binding BindingContext.RemoveItemCommand, Source={x:Reference Root}, x:DataType=ContentView}"
                                                                      CommandParameter="{Binding .}"/>
                                            </Label.GestureRecognizers>
                                        </Label>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>
                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentView>
