<?xml version="1.0" encoding="utf-8" ?>
<ContentView x:Class="MyCraftyStash.Views.SocialView"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:MyCraftyStash.ViewModels"
             xmlns:views="clr-namespace:MyCraftyStash.Views"
             x:Name="Root"
             x:DataType="vm:SocialViewModel">

    <Grid RowDefinitions="Auto,*">

        <!-- Tab bar -->
        <Grid Grid.Row="0" RowDefinitions="*,1" BackgroundColor="{StaticResource StashCard}">
            <HorizontalStackLayout Margin="20,0" Spacing="4">
                <Border Padding="16,12" BackgroundColor="Transparent">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding ShowCalendarCommand}"/>
                    </Border.GestureRecognizers>
                    <Grid RowDefinitions="*,3" RowSpacing="8">
                        <HorizontalStackLayout Spacing="8">
                            <Label Text="▣" FontSize="15" VerticalOptions="Center" TextColor="{StaticResource StashTextMuted}"/>
                            <Label Text="Calendar" FontSize="13" FontAttributes="Bold" VerticalOptions="Center">
                                <Label.Triggers>
                                    <DataTrigger TargetType="Label" Binding="{Binding IsCalendarTab}" Value="True">
                                        <Setter Property="TextColor" Value="{StaticResource StashPrimary}"/>
                                    </DataTrigger>
                                    <DataTrigger TargetType="Label" Binding="{Binding IsCalendarTab}" Value="False">
                                        <Setter Property="TextColor" Value="{StaticResource StashTextMuted}"/>
                                    </DataTrigger>
                                </Label.Triggers>
                            </Label>
                        </HorizontalStackLayout>
                        <BoxView Grid.Row="1" IsVisible="{Binding IsCalendarTab}" Color="{StaticResource StashPrimary}"/>
                    </Grid>
                </Border>
                <Border Padding="16,12" BackgroundColor="Transparent">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding ShowAddressBookCommand}"/>
                    </Border.GestureRecognizers>
                    <Grid RowDefinitions="*,3" RowSpacing="8">
                        <HorizontalStackLayout Spacing="8">
                            <Label Text="☰" FontSize="15" VerticalOptions="Center" TextColor="{StaticResource StashTextMuted}"/>
                            <Label Text="Address Book" FontSize="13" FontAttributes="Bold" VerticalOptions="Center">
                                <Label.Triggers>
                                    <DataTrigger TargetType="Label" Binding="{Binding IsAddressBookTab}" Value="True">
                                        <Setter Property="TextColor" Value="{StaticResource StashPrimary}"/>
                                    </DataTrigger>
                                    <DataTrigger TargetType="Label" Binding="{Binding IsAddressBookTab}" Value="False">
                                        <Setter Property="TextColor" Value="{StaticResource StashTextMuted}"/>
                                    </DataTrigger>
                                </Label.Triggers>
                            </Label>
                        </HorizontalStackLayout>
                        <BoxView Grid.Row="1" IsVisible="{Binding IsAddressBookTab}" Color="{StaticResource StashPrimary}"/>
                    </Grid>
                </Border>
            </HorizontalStackLayout>
            <BoxView Grid.Row="1" Color="{StaticResource StashBorder}" HeightRequest="1"/>
        </Grid>

        <!-- Tab content (IsVisible must resolve against the SocialViewModel, not
             the child VM that each view's BindingContext points at) -->
        <Grid Grid.Row="1">
            <views:CalendarView BindingContext="{Binding CalendarVM}"
                                IsVisible="{Binding BindingContext.IsCalendarTab, Source={x:Reference Root}, x:DataType=vm:SocialViewModel}"/>
            <views:AddressBookView BindingContext="{Binding AddressBookVM}"
                                   IsVisible="{Binding BindingContext.IsAddressBookTab, Source={x:Reference Root}, x:DataType=vm:SocialViewModel}"/>
        </Grid>
    </Grid>
</ContentView>
