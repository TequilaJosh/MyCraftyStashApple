<?xml version="1.0" encoding="utf-8" ?>
<ContentView x:Class="MyCraftyStash.Views.CalendarView"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:MyCraftyStash.ViewModels"
             xmlns:models="clr-namespace:MyCraftyStash.Models"
             x:Name="Root"
             x:DataType="vm:CalendarViewModel">

    <ContentView.Resources>
        <Color x:Key="TodaySoft">#F4E5D0</Color>
        <Color x:Key="SelectedSoft">#F8E0E1</Color>
        <Color x:Key="SuccessGreen">#3F8F62</Color>
        <Color x:Key="SuccessSoft">#E2EFE6</Color>
        <Color x:Key="DangerSoft">#F8E0E1</Color>
        <Color x:Key="DangerRed">#A82C32</Color>
        <Style x:Key="MiniBtn" TargetType="Button">
            <Setter Property="BackgroundColor" Value="{StaticResource StashSidebar}"/>
            <Setter Property="TextColor" Value="{StaticResource StashText}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
    </ContentView.Resources>

    <Grid ColumnDefinitions="*,340">

        <!-- ══════ MONTH GRID ══════ -->
        <Grid Grid.Column="0" RowDefinitions="Auto,Auto,*">

            <!-- Month nav -->
            <Border Grid.Row="0" BackgroundColor="{StaticResource StashCard}" Padding="20,14">
                <HorizontalStackLayout Spacing="0" VerticalOptions="Center">
                    <Button Text="◀" Style="{StaticResource MiniBtn}" WidthRequest="34" HeightRequest="34" Padding="0" Command="{Binding PreviousMonthCommand}"/>
                    <Label Text="{Binding CurrentMonthLabel}" FontSize="20" FontAttributes="Bold" TextColor="{StaticResource StashText}" Margin="16,0" VerticalOptions="Center"/>
                    <Button Text="▶" Style="{StaticResource MiniBtn}" WidthRequest="34" HeightRequest="34" Padding="0" Command="{Binding NextMonthCommand}"/>
                    <Button Text="Today" Style="{StaticResource MiniBtn}" Margin="12,0,0,0" Command="{Binding GoToTodayCommand}"/>
                </HorizontalStackLayout>
            </Border>

            <!-- Day-of-week header -->
            <Grid Grid.Row="1" ColumnDefinitions="*,*,*,*,*,*,*" BackgroundColor="{StaticResource StashCard}" Padding="0,6">
                <Label Grid.Column="0" Text="SUN" FontSize="11" FontAttributes="Bold" TextColor="{StaticResource StashTextMuted}" HorizontalTextAlignment="Center"/>
                <Label Grid.Column="1" Text="MON" FontSize="11" FontAttributes="Bold" TextColor="{StaticResource StashTextMuted}" HorizontalTextAlignment="Center"/>
                <Label Grid.Column="2" Text="TUE" FontSize="11" FontAttributes="Bold" TextColor="{StaticResource StashTextMuted}" HorizontalTextAlignment="Center"/>
                <Label Grid.Column="3" Text="WED" FontSize="11" FontAttributes="Bold" TextColor="{StaticResource StashTextMuted}" HorizontalTextAlignment="Center"/>
                <Label Grid.Column="4" Text="THU" FontSize="11" FontAttributes="Bold" TextColor="{StaticResource StashTextMuted}" HorizontalTextAlignment="Center"/>
                <Label Grid.Column="5" Text="FRI" FontSize="11" FontAttributes="Bold" TextColor="{StaticResource StashTextMuted}" HorizontalTextAlignment="Center"/>
                <Label Grid.Column="6" Text="SAT" FontSize="11" FontAttributes="Bold" TextColor="{StaticResource StashTextMuted}" HorizontalTextAlignment="Center"/>
            </Grid>

            <!-- 6×7 day cells -->
            <CollectionView Grid.Row="2" ItemsSource="{Binding DayCells}" SelectionMode="None">
                <CollectionView.ItemsLayout>
                    <GridItemsLayout Orientation="Vertical" Span="7"/>
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="vm:CalendarDayCell">
                        <Border StrokeThickness="1" Stroke="{StaticResource StashBorder}" MinimumHeightRequest="86"
                                BackgroundColor="{StaticResource StashCard}" Padding="4">
                            <Border.Triggers>
                                <DataTrigger TargetType="Border" Binding="{Binding IsOtherMonth}" Value="True">
                                    <Setter Property="BackgroundColor" Value="{StaticResource StashBackground}"/>
                                </DataTrigger>
                                <DataTrigger TargetType="Border" Binding="{Binding IsSelected}" Value="True">
                                    <Setter Property="BackgroundColor" Value="{StaticResource SelectedSoft}"/>
                                </DataTrigger>
                                <DataTrigger TargetType="Border" Binding="{Binding IsToday}" Value="True">
                                    <Setter Property="BackgroundColor" Value="{StaticResource TodaySoft}"/>
                                </DataTrigger>
                            </Border.Triggers>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding BindingContext.SelectDayCellCommand, Source={x:Reference Root}, x:DataType=ContentView}" CommandParameter="{Binding .}"/>
                            </Border.GestureRecognizers>
                            <Grid RowDefinitions="Auto,*" RowSpacing="2">
                                <!-- Day number -->
                                <Border Grid.Row="0" WidthRequest="26" HeightRequest="26" StrokeShape="RoundRectangle 13" StrokeThickness="0"
                                        HorizontalOptions="Start" BackgroundColor="Transparent">
                                    <Border.Triggers>
                                        <DataTrigger TargetType="Border" Binding="{Binding IsToday}" Value="True">
                                            <Setter Property="BackgroundColor" Value="{StaticResource StashPrimary}"/>
                                        </DataTrigger>
                                        <DataTrigger TargetType="Border" Binding="{Binding IsSelected}" Value="True">
                                            <Setter Property="BackgroundColor" Value="{StaticResource StashPrimary}"/>
                                        </DataTrigger>
                                    </Border.Triggers>
                                    <Label Text="{Binding DayNumber}" FontSize="12" FontAttributes="Bold" HorizontalOptions="Center" VerticalOptions="Center"
                                           TextColor="{StaticResource StashText}">
                                        <Label.Triggers>
                                            <DataTrigger TargetType="Label" Binding="{Binding IsOtherMonth}" Value="True">
                                                <Setter Property="TextColor" Value="{StaticResource StashTextMuted}"/>
                                            </DataTrigger>
                                            <DataTrigger TargetType="Label" Binding="{Binding IsToday}" Value="True">
                                                <Setter Property="TextColor" Value="White"/>
                                            </DataTrigger>
                                            <DataTrigger TargetType="Label" Binding="{Binding IsSelected}" Value="True">
                                                <Setter Property="TextColor" Value="White"/>
                                            </DataTrigger>
                                        </Label.Triggers>
                                    </Label>
                                </Border>
                                <!-- Event pills -->
                                <VerticalStackLayout Grid.Row="1" Spacing="1" Margin="0,2,0,0" BindableLayout.ItemsSource="{Binding Events}">
                                    <BindableLayout.ItemTemplate>
                                        <DataTemplate x:DataType="models:CalendarEvent">
                                            <Border BackgroundColor="{StaticResource StashPrimary}" StrokeThickness="0" StrokeShape="RoundRectangle 3" Padding="4,1">
                                                <Label Text="{Binding Title}" FontSize="10" TextColor="White" LineBreakMode="TailTruncation"/>
                                            </Border>
                                        </DataTemplate>
                                    </BindableLayout.ItemTemplate>
                                </VerticalStackLayout>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Grid>

        <!-- ══════ SIDEBAR ══════ -->
        <Grid Grid.Column="1" BackgroundColor="{StaticResource StashSidebar}" RowDefinitions="Auto,*">

            <!-- Selected-day header -->
            <Border Grid.Row="0" BackgroundColor="{StaticResource StashCard}" Padding="16,12"
                    Stroke="{StaticResource StashBorder}" StrokeThickness="0,0,0,1">
                <Grid ColumnDefinitions="*,Auto">
                    <VerticalStackLayout Grid.Column="0" Spacing="1">
                        <Label Text="{Binding SelectedDayLabel}" FontSize="16" FontAttributes="Bold" TextColor="{StaticResource StashText}"/>
                        <Label Text="{Binding SelectedDayCountLabel}" FontSize="11" TextColor="{StaticResource StashTextMuted}"/>
                    </VerticalStackLayout>
                    <Button Grid.Column="1" Text="+ Add Event" Style="{StaticResource MiniBtn}" VerticalOptions="Center"
                            IsVisible="{Binding HasSelectedDay}" Command="{Binding StartAddCommand}"/>
                </Grid>
            </Border>

            <ScrollView Grid.Row="1">
                <VerticalStackLayout Padding="12" Spacing="8">

                    <!-- Status banner -->
                    <Border IsVisible="{Binding StatusMessage, Converter={StaticResource IsNotNullConverter}}"
                            BackgroundColor="{StaticResource SuccessSoft}" StrokeThickness="0" StrokeShape="RoundRectangle 6" Padding="12,8">
                        <Label Text="{Binding StatusMessage}" TextColor="{StaticResource SuccessGreen}" FontAttributes="Bold" FontSize="12"/>
                    </Border>

                    <!-- Placeholder: no day selected -->
                    <Label Text="Tap any day to view or add events." FontSize="13" TextColor="{StaticResource StashTextMuted}"
                           HorizontalTextAlignment="Center" Margin="8,40,8,0"
                           IsVisible="{Binding HasSelectedDay, Converter={StaticResource InvertedBoolConverter}}"/>

                    <!-- ADD/EDIT FORM -->
                    <VerticalStackLayout Spacing="10" IsVisible="{Binding IsFormOpen}">
                        <Label Text="{Binding FormHeading}" FontSize="16" FontAttributes="Bold" TextColor="{StaticResource StashText}"/>
                        <Border IsVisible="{Binding ErrorMessage, Converter={StaticResource IsNotNullConverter}}"
                                BackgroundColor="{StaticResource DangerSoft}" StrokeThickness="0" StrokeShape="RoundRectangle 6" Padding="10,7">
                            <Label Text="{Binding ErrorMessage}" TextColor="{StaticResource DangerRed}" FontSize="12"/>
                        </Border>

                        <Label Text="Title *" FontSize="11" FontAttributes="Bold" TextColor="{StaticResource StashTextMuted}"/>
                        <Border BackgroundColor="{StaticResource StashSurface}" Stroke="{StaticResource StashBorder}" StrokeThickness="1" StrokeShape="RoundRectangle 8" Padding="8,2">
                            <Entry Text="{Binding EditTitle}" BackgroundColor="Transparent" TextColor="{StaticResource StashText}"/>
                        </Border>

                        <Label Text="Description" FontSize="11" FontAttributes="Bold" TextColor="{StaticResource StashTextMuted}"/>
                        <Border BackgroundColor="{StaticResource StashSurface}" Stroke="{StaticResource StashBorder}" StrokeThickness="1" StrokeShape="RoundRectangle 8" Padding="8,4">
                            <Editor Text="{Binding EditDescription}" AutoSize="TextChanges" MinimumHeightRequest="56" BackgroundColor="Transparent" TextColor="{StaticResource StashText}"/>
                        </Border>

                        <Label Text="Date *" FontSize="11" FontAttributes="Bold" TextColor="{StaticResource StashTextMuted}"/>
                        <DatePicker Date="{Binding EditDate}" TextColor="{StaticResource StashText}"/>

                        <HorizontalStackLayout Spacing="8">
                            <CheckBox IsChecked="{Binding EditIsAllDay}"/>
                            <Label Text="All Day Event" FontSize="13" TextColor="{StaticResource StashText}" VerticalOptions="Center"/>
                        </HorizontalStackLayout>

                        <VerticalStackLayout Spacing="4" IsVisible="{Binding ShowTimePicker}">
                            <Label Text="Time" FontSize="11" FontAttributes="Bold" TextColor="{StaticResource StashTextMuted}"/>
                            <HorizontalStackLayout Spacing="6" VerticalOptions="Center">
                                <Border BackgroundColor="{StaticResource StashSurface}" Stroke="{StaticResource StashBorder}" StrokeThickness="1" StrokeShape="RoundRectangle 8" Padding="6,2" WidthRequest="52">
                                    <Entry Text="{Binding EditTimeHour}" Keyboard="Numeric" MaxLength="2" BackgroundColor="Transparent" TextColor="{StaticResource StashText}"/>
                                </Border>
                                <Label Text=":" FontSize="16" TextColor="{StaticResource StashText}" VerticalOptions="Center"/>
                                <Border BackgroundColor="{StaticResource StashSurface}" Stroke="{StaticResource StashBorder}" StrokeThickness="1" StrokeShape="RoundRectangle 8" Padding="6,2" WidthRequest="52">
                                    <Entry Text="{Binding EditTimeMinute}" Keyboard="Numeric" MaxLength="2" BackgroundColor="Transparent" TextColor="{StaticResource StashText}"/>
                                </Border>
                                <Picker ItemsSource="{Binding AmPmOptions}" SelectedItem="{Binding EditTimeAmPm}" WidthRequest="70" TextColor="{StaticResource StashText}"/>
                            </HorizontalStackLayout>
                        </VerticalStackLayout>

                        <Label Text="Remind me" FontSize="11" FontAttributes="Bold" TextColor="{StaticResource StashTextMuted}"/>
                        <Picker ItemsSource="{Binding ReminderOptions}" SelectedItem="{Binding EditReminderLabel}" TextColor="{StaticResource StashText}"/>

                        <Label Text="Color" FontSize="11" FontAttributes="Bold" TextColor="{StaticResource StashTextMuted}"/>
                        <FlexLayout Wrap="Wrap" BindableLayout.ItemsSource="{Binding ColorOptions}">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="x:String">
                                    <Border WidthRequest="28" HeightRequest="28" StrokeShape="RoundRectangle 14" StrokeThickness="0" Margin="3"
                                            BackgroundColor="{Binding .}">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding BindingContext.SetColorCommand, Source={x:Reference Root}, x:DataType=ContentView}" CommandParameter="{Binding .}"/>
                                        </Border.GestureRecognizers>
                                    </Border>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </FlexLayout>

                        <HorizontalStackLayout Spacing="8" Margin="0,4,0,0">
                            <Button Text="Save" BackgroundColor="{StaticResource StashPrimary}" TextColor="White" CornerRadius="10" Padding="14,8" Command="{Binding SaveEventCommand}"/>
                            <Button Text="Cancel" Style="{StaticResource MiniBtn}" Padding="14,8" Command="{Binding CancelFormCommand}"/>
                        </HorizontalStackLayout>
                    </VerticalStackLayout>

                    <!-- EVENT LIST (when not editing) -->
                    <VerticalStackLayout Spacing="8" IsVisible="{Binding IsFormOpen, Converter={StaticResource InvertedBoolConverter}}">
                        <Label Text="No events on this day. Tap '+ Add Event' to create one." FontSize="13" TextColor="{StaticResource StashTextMuted}"
                               HorizontalTextAlignment="Center" Margin="8,20,8,0">
                            <Label.IsVisible>
                                <MultiBinding Converter="{StaticResource AllTrueConverter}">
                                    <Binding Path="HasSelectedDay"/>
                                    <Binding Path="SelectedDayEmpty"/>
                                </MultiBinding>
                            </Label.IsVisible>
                        </Label>
                        <VerticalStackLayout BindableLayout.ItemsSource="{Binding SelectedDayEvents}" Spacing="8">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="models:CalendarEvent">
                                    <Border BackgroundColor="{StaticResource StashCard}" Stroke="{StaticResource StashBorder}" StrokeThickness="1" StrokeShape="RoundRectangle 8" Padding="12,10">
                                        <Grid ColumnDefinitions="6,*,Auto" ColumnSpacing="10">
                                            <Border Grid.Column="0" WidthRequest="6" StrokeShape="RoundRectangle 3" StrokeThickness="0" BackgroundColor="{StaticResource StashPrimary}"/>
                                            <VerticalStackLayout Grid.Column="1" Spacing="1" VerticalOptions="Center">
                                                <Label Text="{Binding Title}" FontAttributes="Bold" FontSize="13" TextColor="{StaticResource StashText}" LineBreakMode="TailTruncation"/>
                                                <Label Text="{Binding DisplayTime}" FontSize="11" TextColor="{StaticResource StashTextMuted}"/>
                                                <Label Text="{Binding Description}" FontSize="11" TextColor="{StaticResource StashTextMuted}" IsVisible="{Binding Description, Converter={StaticResource IsNotNullConverter}}"/>
                                            </VerticalStackLayout>
                                            <HorizontalStackLayout Grid.Column="2" Spacing="4" VerticalOptions="Start">
                                                <Button Text="✏" FontSize="13" WidthRequest="28" HeightRequest="28" Padding="0" Style="{StaticResource MiniBtn}"
                                                        Command="{Binding BindingContext.StartEditCommand, Source={x:Reference Root}, x:DataType=ContentView}" CommandParameter="{Binding .}"/>
                                                <Button Text="✕" FontSize="13" WidthRequest="28" HeightRequest="28" Padding="0"
                                                        BackgroundColor="{StaticResource StashSidebar}" TextColor="{StaticResource DangerRed}" CornerRadius="8"
                                                        Command="{Binding BindingContext.DeleteEventCommand, Source={x:Reference Root}, x:DataType=ContentView}" CommandParameter="{Binding .}"/>
                                            </HorizontalStackLayout>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </ScrollView>
        </Grid>
    </Grid>
</ContentView>
