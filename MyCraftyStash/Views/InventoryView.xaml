<?xml version="1.0" encoding="utf-8" ?>
<ContentView x:Class="MyCraftyStash.Views.InventoryView"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:MyCraftyStash.ViewModels"
             xmlns:models="clr-namespace:MyCraftyStash.Models"
             x:Name="Root"
             x:DataType="vm:InventoryViewModel">

    <Grid RowDefinitions="Auto,*">

        <!-- Header + search + filters -->
        <VerticalStackLayout Grid.Row="0" Spacing="0" Padding="24,18,24,8">
            <Label Text="My Crafty Stash  /  Inventory" Style="{StaticResource Breadcrumb}"/>
            <Grid ColumnDefinitions="*,Auto" Margin="0,4,0,0">
                <Label Text="Inventory" Style="{StaticResource PageTitle}"/>
                <Button Grid.Column="1" Text="+ Add Item" Command="{Binding AddItemCommand}"
                        Style="{StaticResource PrimaryButton}" VerticalOptions="Center"/>
            </Grid>
            <Label Text="Manage your craft supplies — search, filter, and add new items."
                   Style="{StaticResource PageSubtitle}"/>

            <!-- Search row -->
            <Grid ColumnDefinitions="*,180,Auto,Auto" ColumnSpacing="10" Margin="0,14,0,0">
                <Entry Grid.Column="0" Text="{Binding SearchText}" Placeholder="Search your stash"
                       ReturnCommand="{Binding SearchCommand}"/>
                <Picker Grid.Column="1" ItemsSource="{Binding Types}" SelectedItem="{Binding SelectedType}" Title="All types"/>
                <Button Grid.Column="2" Text="Search" Command="{Binding SearchCommand}" Style="{StaticResource PrimaryButton}"/>
                <Button Grid.Column="3" Text="Clear" Command="{Binding ClearFiltersCommand}" Style="{StaticResource SecondaryButton}"/>
            </Grid>

            <!-- Filter toggles -->
            <HorizontalStackLayout Spacing="18" Margin="0,10,0,0">
                <HorizontalStackLayout Spacing="4">
                    <CheckBox IsChecked="{Binding NameOnly}"/>
                    <Label Text="Name only" VerticalOptions="Center" FontSize="12" TextColor="{StaticResource StashText}"/>
                </HorizontalStackLayout>
                <HorizontalStackLayout Spacing="4">
                    <CheckBox IsChecked="{Binding ThemeOnly}"/>
                    <Label Text="Theme only" VerticalOptions="Center" FontSize="12" TextColor="{StaticResource StashText}"/>
                </HorizontalStackLayout>
                <HorizontalStackLayout Spacing="4">
                    <CheckBox IsChecked="{Binding DiscontinuedOnly}"/>
                    <Label Text="Discontinued only" VerticalOptions="Center" FontSize="12" TextColor="{StaticResource StashText}"/>
                </HorizontalStackLayout>
                <Label Text="{Binding ResultSummary}" VerticalOptions="Center" FontSize="12" TextColor="{StaticResource StashTextMuted}"/>
            </HorizontalStackLayout>
        </VerticalStackLayout>

        <RefreshView Grid.Row="1" Command="{Binding DoRefreshCommand}" IsRefreshing="{Binding IsRefreshing}">
            <CollectionView ItemsSource="{Binding Items}" SelectionMode="None" Margin="16,0">
                <CollectionView.ItemsLayout>
                    <GridItemsLayout Orientation="Vertical" Span="3"
                                     HorizontalItemSpacing="12" VerticalItemSpacing="12"/>
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:Item">
                        <Border StrokeShape="RoundRectangle 12" StrokeThickness="1" Stroke="{StaticResource StashBorder}"
                                BackgroundColor="{StaticResource StashCard}" Padding="10" HeightRequest="238">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding BindingContext.OpenItemCommand, Source={x:Reference Root}, x:DataType=ContentView}"
                                                      CommandParameter="{Binding .}"/>
                            </Border.GestureRecognizers>
                            <!-- Fixed-height card: photo fills the top, name/theme pinned to the bottom -->
                            <Grid RowDefinitions="*,Auto" RowSpacing="8">
                                <!-- Photo + overlaid badges (white backdrop hides pillarbox bars) -->
                                <Grid Grid.Row="0">
                                    <Border StrokeShape="RoundRectangle 8" StrokeThickness="0" BackgroundColor="White">
                                        <Image Source="{Binding ImageUrl, Converter={StaticResource ImageStringConverter}}" Aspect="AspectFit"/>
                                    </Border>
                                    <!-- Subtype/type badge (top-left) -->
                                    <Border BackgroundColor="{StaticResource StashBadge}" StrokeThickness="0" StrokeShape="RoundRectangle 4"
                                            Padding="6,2" HorizontalOptions="Start" VerticalOptions="Start" Margin="8">
                                        <Label Text="{Binding TypeSubtypeBadge}" FontSize="10" FontAttributes="Bold" TextColor="{StaticResource StashText}"/>
                                    </Border>
                                    <!-- Layers badge (bottom-right, stencils) -->
                                    <Border BackgroundColor="{StaticResource StashPrimary}" StrokeThickness="0" StrokeShape="RoundRectangle 4"
                                            Padding="6,2" HorizontalOptions="End" VerticalOptions="End" Margin="8"
                                            IsVisible="{Binding ShowLayersBadge}">
                                        <Label Text="{Binding LayersText}" FontSize="10" FontAttributes="Bold" TextColor="White"/>
                                    </Border>
                                    <!-- Discontinued badge (bottom-left) -->
                                    <Border BackgroundColor="{StaticResource ErrorRed}" StrokeThickness="0" StrokeShape="RoundRectangle 4"
                                            Padding="6,2" HorizontalOptions="Start" VerticalOptions="End" Margin="8"
                                            IsVisible="{Binding IsDiscontinued}">
                                        <Label Text="Discontinued" FontSize="10" FontAttributes="Bold" TextColor="White"/>
                                    </Border>
                                </Grid>
                                <!-- Name + theme (left) and stock badge (right) -->
                                <Grid Grid.Row="1" ColumnDefinitions="*,Auto" ColumnSpacing="6">
                                    <VerticalStackLayout Grid.Column="0" Spacing="1" VerticalOptions="End">
                                        <Label Text="{Binding Name}" FontAttributes="Bold" FontSize="14"
                                               TextColor="{StaticResource StashText}" MaxLines="2" LineBreakMode="TailTruncation"/>
                                        <Label Text="{Binding Theme}" FontSize="12" TextColor="{StaticResource StashPrimary}"
                                               MaxLines="1" LineBreakMode="TailTruncation" IsVisible="{Binding HasTheme}"/>
                                    </VerticalStackLayout>
                                    <Border Grid.Column="1" BackgroundColor="{StaticResource StashSidebar}" StrokeThickness="0"
                                            StrokeShape="RoundRectangle 4" Padding="6,2" VerticalOptions="End"
                                            IsVisible="{Binding HasStock}">
                                        <Label Text="{Binding StockText}" FontSize="11" FontAttributes="Bold" TextColor="{StaticResource StashText}"/>
                                    </Border>
                                </Grid>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
                <CollectionView.EmptyView>
                    <VerticalStackLayout Spacing="10" VerticalOptions="Center" Padding="40">
                        <Label Text="Nothing here yet" FontSize="20" FontAttributes="Bold"
                               HorizontalOptions="Center" TextColor="{StaticResource StashText}"/>
                        <Label Text="Tap Add Item to put your first item in the stash, or adjust your search."
                               HorizontalTextAlignment="Center" TextColor="{StaticResource StashTextMuted}"/>
                    </VerticalStackLayout>
                </CollectionView.EmptyView>
            </CollectionView>
        </RefreshView>

        <ActivityIndicator Grid.Row="1" IsRunning="{Binding Busy}" IsVisible="{Binding Busy}"
                           VerticalOptions="Center" HorizontalOptions="Center"/>
    </Grid>
</ContentView>
