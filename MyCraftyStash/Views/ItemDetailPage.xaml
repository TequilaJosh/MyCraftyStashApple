<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="MyCraftyStash.Views.ItemDetailPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:MyCraftyStash.ViewModels"
             x:DataType="vm:ItemDetailViewModel"
             Title="{Binding Item.Name}">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Edit" Command="{Binding EditCommand}"/>
        <ToolbarItem Text="Delete" Command="{Binding DeleteCommand}"/>
    </ContentPage.ToolbarItems>

    <ScrollView>
        <VerticalStackLayout Spacing="20" Padding="20" MaximumWidthRequest="700">

            <Border StrokeShape="RoundRectangle 12" StrokeThickness="0" BackgroundColor="White">
                <Image Source="{Binding Item.ImageUrl, Converter={StaticResource ImageStringConverter}}"
                       Aspect="AspectFit" MaximumHeightRequest="320"/>
            </Border>

            <Label Text="Discontinued"
                   IsVisible="{Binding Item.IsDiscontinued}"
                   TextColor="{StaticResource ErrorRed}"
                   FontAttributes="Bold"/>

            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="24" RowSpacing="10"
                  RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto">
                <Label Grid.Row="0" Text="Type" TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray300}}"/>
                <Label Grid.Row="0" Grid.Column="1" Text="{Binding Item.Type, TargetNullValue='—'}"/>
                <Label Grid.Row="1" Text="Subtype" TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray300}}"/>
                <Label Grid.Row="1" Grid.Column="1" Text="{Binding Item.Subtype, TargetNullValue='—'}"/>
                <Label Grid.Row="2" Text="Theme" TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray300}}"/>
                <Label Grid.Row="2" Grid.Column="1" Text="{Binding Item.Theme, TargetNullValue='—'}"/>
                <Label Grid.Row="3" Text="Item #" TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray300}}"/>
                <Label Grid.Row="3" Grid.Column="1" Text="{Binding Item.ItemNumber, TargetNullValue='—'}"/>
                <Label Grid.Row="4" Text="Price" TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray300}}"/>
                <Label Grid.Row="4" Grid.Column="1" Text="{Binding Item.Price, StringFormat='{0:C}', TargetNullValue='—'}"/>
                <Label Grid.Row="5" Text="Stock" TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray300}}"/>
                <Label Grid.Row="5" Grid.Column="1" Text="{Binding Item.CurrentStock, TargetNullValue='—'}"/>
                <Label Grid.Row="6" Text="Location" TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray300}}"/>
                <Label Grid.Row="6" Grid.Column="1" Text="{Binding Item.Location, TargetNullValue='—'}"/>
                <Label Grid.Row="7" Text="From" TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray300}}"/>
                <Label Grid.Row="7" Grid.Column="1" Text="{Binding Item.PurchasedFrom, TargetNullValue='—'}"/>
            </Grid>

            <VerticalStackLayout Spacing="6" IsVisible="{Binding Item.Notes, Converter={StaticResource IsNotNullConverter}}">
                <Label Text="Notes" FontAttributes="Bold" FontSize="18"/>
                <Label Text="{Binding Item.Notes}"/>
            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
