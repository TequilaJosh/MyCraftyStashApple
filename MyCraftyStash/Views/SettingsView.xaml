<?xml version="1.0" encoding="utf-8" ?>
<ContentView x:Class="MyCraftyStash.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:MyCraftyStash.ViewModels"
             x:DataType="vm:SettingsViewModel">

    <Grid RowDefinitions="Auto,*">
        <VerticalStackLayout Grid.Row="0" Spacing="0" Padding="24,18,24,8">
            <Label Text="My Crafty Stash  /  Settings" Style="{StaticResource Breadcrumb}"/>
            <Label Text="Settings" Style="{StaticResource PageTitle}" Margin="0,4,0,0"/>
        </VerticalStackLayout>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="20" Padding="24,0,24,24" MaximumWidthRequest="620">
                <Label Text="Your stash" FontAttributes="Bold" FontSize="18" TextColor="{StaticResource StashText}"/>
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="24" RowSpacing="10" RowDefinitions="Auto,Auto">
                    <Label Grid.Row="0" Text="Items" TextColor="{StaticResource StashTextMuted}"/>
                    <Label Grid.Row="0" Grid.Column="1" Text="{Binding ItemCount}" TextColor="{StaticResource StashText}"/>
                    <Label Grid.Row="1" Text="Database" TextColor="{StaticResource StashTextMuted}"/>
                    <Label Grid.Row="1" Grid.Column="1" Text="{Binding DatabaseLocation}" FontSize="12"
                           TextColor="{StaticResource StashText}" LineBreakMode="CharacterWrap"/>
                </Grid>

                <Label Text="About" FontAttributes="Bold" FontSize="18" Margin="0,20,0,0" TextColor="{StaticResource StashText}"/>
                <Label Text="Version 0.1.0" TextColor="{StaticResource StashText}"/>
                <Label Text="My Crafty Stash for Mac &amp; iPad. Your inventory lives in a database on this device."
                       TextColor="{StaticResource StashTextMuted}"/>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentView>
