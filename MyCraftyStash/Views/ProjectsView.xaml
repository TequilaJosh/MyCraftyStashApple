<?xml version="1.0" encoding="utf-8" ?>
<ContentView x:Class="MyCraftyStash.Views.ProjectsView"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:MyCraftyStash.ViewModels"
             xmlns:models="clr-namespace:MyCraftyStash.Models"
             x:Name="Root"
             x:DataType="vm:ProjectsViewModel">

    <Grid RowDefinitions="Auto,Auto,*">

        <VerticalStackLayout Grid.Row="0" Spacing="0" Padding="24,18,24,8">
            <Label Text="My Crafty Stash  /  Projects" Style="{StaticResource Breadcrumb}"/>
            <Grid ColumnDefinitions="*,Auto" Margin="0,4,0,0">
                <Label Text="Project gallery" Style="{StaticResource PageTitle}"/>
                <Button Grid.Column="1" Text="+ Add Project" Command="{Binding AddProjectCommand}"
                        Style="{StaticResource PrimaryButton}" VerticalOptions="Center"/>
            </Grid>
            <Label Text="Track your makes — each linked to the supplies you used." Style="{StaticResource PageSubtitle}"/>
        </VerticalStackLayout>

        <SearchBar Grid.Row="1" Placeholder="Search your projects"
                   Text="{Binding SearchText}" SearchCommand="{Binding SearchCommand}"
                   Margin="20,0,20,6"/>

        <RefreshView Grid.Row="2" Command="{Binding DoRefreshCommand}" IsRefreshing="{Binding IsRefreshing}">
            <CollectionView ItemsSource="{Binding Projects}" SelectionMode="None" Margin="16,0">
                <CollectionView.ItemsLayout>
                    <GridItemsLayout Orientation="Vertical" Span="3"
                                     HorizontalItemSpacing="12" VerticalItemSpacing="12"/>
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:Project">
                        <Border StrokeShape="RoundRectangle 12" StrokeThickness="0"
                                BackgroundColor="{StaticResource StashCard}" Padding="10">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding BindingContext.OpenProjectCommand, Source={x:Reference Root}, x:DataType=ContentView}"
                                                      CommandParameter="{Binding .}"/>
                            </Border.GestureRecognizers>
                            <VerticalStackLayout Spacing="6">
                                <Border StrokeShape="RoundRectangle 8" StrokeThickness="0" BackgroundColor="White" HeightRequest="130">
                                    <Image Source="{Binding ImageUrl, Converter={StaticResource ImageStringConverter}}"
                                           Aspect="AspectFill" HeightRequest="130"/>
                                </Border>
                                <Label Text="{Binding Name}" FontAttributes="Bold" FontSize="15"
                                       TextColor="{StaticResource StashText}" MaxLines="2" LineBreakMode="TailTruncation"/>
                                <Label Text="{Binding ProjectItems.Count, StringFormat='{0} items used'}"
                                       FontSize="12" TextColor="{StaticResource StashTextMuted}"/>
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
                <CollectionView.EmptyView>
                    <VerticalStackLayout Spacing="10" VerticalOptions="Center" Padding="40">
                        <Label Text="No projects yet" FontSize="20" FontAttributes="Bold"
                               HorizontalOptions="Center" TextColor="{StaticResource StashText}"/>
                        <Label Text="Tap Add Project to record a make and the supplies you used."
                               HorizontalTextAlignment="Center" TextColor="{StaticResource StashTextMuted}"/>
                    </VerticalStackLayout>
                </CollectionView.EmptyView>
            </CollectionView>
        </RefreshView>

        <ActivityIndicator Grid.Row="2" IsRunning="{Binding Busy}" IsVisible="{Binding Busy}"
                           VerticalOptions="Center" HorizontalOptions="Center"/>
    </Grid>
</ContentView>
