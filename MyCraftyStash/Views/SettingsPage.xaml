<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="MyCraftyStash.Views.SettingsPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:MyCraftyStash.ViewModels"
             x:DataType="vm:SettingsViewModel"
             Title="Settings">

    <VerticalStackLayout Spacing="20" Padding="24" MaximumWidthRequest="620">
        <Label Text="Your stash" FontAttributes="Bold" FontSize="18"/>
        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="24" RowSpacing="10" RowDefinitions="Auto,Auto">
            <Label Grid.Row="0" Text="Items" TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray300}}"/>
            <Label Grid.Row="0" Grid.Column="1" Text="{Binding ItemCount}"/>
            <Label Grid.Row="1" Text="Database" TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray300}}"/>
            <Label Grid.Row="1" Grid.Column="1" Text="{Binding DatabaseLocation}" FontSize="12" LineBreakMode="CharacterWrap"/>
        </Grid>

        <Label Text="About" FontAttributes="Bold" FontSize="18" Margin="0,20,0,0"/>
        <Label Text="Version 0.1.0"/>
        <Label Text="My Crafty Stash for Mac &amp; iPad. Your inventory lives in a database on this device."
               TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray300}}"/>
    </VerticalStackLayout>
</ContentPage>
