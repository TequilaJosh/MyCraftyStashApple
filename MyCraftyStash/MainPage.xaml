<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="MyCraftyStash.MainPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:MyCraftyStash.ViewModels"
             x:DataType="vm:MainViewModel"
             Shell.NavBarIsVisible="False"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="{StaticResource StashBackground}">

    <Grid ColumnDefinitions="248,*">

        <!-- ── Persistent sidebar (never collapses) ── -->
        <Grid Grid.Column="0" BackgroundColor="{StaticResource StashSidebar}"
              RowDefinitions="Auto,*,Auto" Padding="10,12">

            <!-- Brand card -->
            <Border Grid.Row="0" StrokeShape="RoundRectangle 12"
                    Stroke="{StaticResource StashBorder}" StrokeThickness="1"
                    BackgroundColor="{StaticResource StashSidebarSelected}"
                    Padding="12" Margin="4,2,4,8">
                <HorizontalStackLayout Spacing="10">
                    <Label Text="🧵" FontSize="24" VerticalOptions="Center"/>
                    <Label Text="My Crafty Stash" FontAttributes="Bold" FontSize="14"
                           TextColor="{StaticResource StashText}" VerticalOptions="Center"/>
                </HorizontalStackLayout>
            </Border>

            <!-- Scrollable nav -->
            <ScrollView Grid.Row="1">
                <VerticalStackLayout Spacing="0">

                    <Border Style="{StaticResource NavRow}"
                            BackgroundColor="{Binding CurrentRoute, Converter={StaticResource NavSelectedConverter}, ConverterParameter=home}">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding NavigateCommand}" CommandParameter="home"/>
                        </Border.GestureRecognizers>
                        <HorizontalStackLayout Spacing="8">
                            <Label Text="⌂" Style="{StaticResource NavIcon}" TextColor="{StaticResource StashPrimary}"/>
                            <Label Text="Home" Style="{StaticResource NavText}"/>
                        </HorizontalStackLayout>
                    </Border>

                    <Border Style="{StaticResource NavRow}"
                            BackgroundColor="{Binding CurrentRoute, Converter={StaticResource NavSelectedConverter}, ConverterParameter=inventory}">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding NavigateCommand}" CommandParameter="inventory"/>
                        </Border.GestureRecognizers>
                        <HorizontalStackLayout Spacing="8">
                            <Label Text="◰" Style="{StaticResource NavIcon}"/>
                            <Label Text="Inventory" Style="{StaticResource NavText}"/>
                        </HorizontalStackLayout>
                    </Border>
                    <Border Style="{StaticResource NavRow}" Padding="46,7" BackgroundColor="Transparent">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding AddItemCommand}"/>
                        </Border.GestureRecognizers>
                        <Label Text="Add Item" FontSize="13" TextColor="{StaticResource StashTextMuted}" VerticalOptions="Center"/>
                    </Border>

                    <Border Style="{StaticResource NavRow}"
                            BackgroundColor="{Binding CurrentRoute, Converter={StaticResource NavSelectedConverter}, ConverterParameter=sentiment}">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding NavigateCommand}" CommandParameter="sentiment"/>
                        </Border.GestureRecognizers>
                        <HorizontalStackLayout Spacing="8">
                            <Label Text="❝" Style="{StaticResource NavIcon}"/>
                            <Label Text="Sentiment Search" Style="{StaticResource NavText}"/>
                        </HorizontalStackLayout>
                    </Border>

                    <Border Style="{StaticResource NavRow}"
                            BackgroundColor="{Binding CurrentRoute, Converter={StaticResource NavSelectedConverter}, ConverterParameter=inspiration}">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding NavigateCommand}" CommandParameter="inspiration"/>
                        </Border.GestureRecognizers>
                        <HorizontalStackLayout Spacing="8">
                            <Label Text="✦" Style="{StaticResource NavIcon}"/>
                            <Label Text="Inspiration" Style="{StaticResource NavText}"/>
                        </HorizontalStackLayout>
                    </Border>

                    <Border Style="{StaticResource NavRow}"
                            BackgroundColor="{Binding CurrentRoute, Converter={StaticResource NavSelectedConverter}, ConverterParameter=wishlist}">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding NavigateCommand}" CommandParameter="wishlist"/>
                        </Border.GestureRecognizers>
                        <HorizontalStackLayout Spacing="8">
                            <Label Text="♡" Style="{StaticResource NavIcon}"/>
                            <Label Text="Wish List" Style="{StaticResource NavText}"/>
                        </HorizontalStackLayout>
                    </Border>

                    <Border Style="{StaticResource NavRow}"
                            BackgroundColor="{Binding CurrentRoute, Converter={StaticResource NavSelectedConverter}, ConverterParameter=colormatch}">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding NavigateCommand}" CommandParameter="colormatch"/>
                        </Border.GestureRecognizers>
                        <HorizontalStackLayout Spacing="8">
                            <Label Text="▦" Style="{StaticResource NavIcon}"/>
                            <Label Text="Color Match" Style="{StaticResource NavText}"/>
                        </HorizontalStackLayout>
                    </Border>

                    <Border Style="{StaticResource NavRow}"
                            BackgroundColor="{Binding CurrentRoute, Converter={StaticResource NavSelectedConverter}, ConverterParameter=envelope}">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding NavigateCommand}" CommandParameter="envelope"/>
                        </Border.GestureRecognizers>
                        <HorizontalStackLayout Spacing="8">
                            <Label Text="✉" Style="{StaticResource NavIcon}"/>
                            <Label Text="Envelope &amp; Box" Style="{StaticResource NavText}"/>
                        </HorizontalStackLayout>
                    </Border>

                    <Border Style="{StaticResource NavRow}"
                            BackgroundColor="{Binding CurrentRoute, Converter={StaticResource NavSelectedConverter}, ConverterParameter=social}">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding NavigateCommand}" CommandParameter="social"/>
                        </Border.GestureRecognizers>
                        <HorizontalStackLayout Spacing="8">
                            <Label Text="❀" Style="{StaticResource NavIcon}"/>
                            <Label Text="Social" Style="{StaticResource NavText}"/>
                        </HorizontalStackLayout>
                    </Border>

                    <Border Style="{StaticResource NavRow}"
                            BackgroundColor="{Binding CurrentRoute, Converter={StaticResource NavSelectedConverter}, ConverterParameter=projects}">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding NavigateCommand}" CommandParameter="projects"/>
                        </Border.GestureRecognizers>
                        <HorizontalStackLayout Spacing="8">
                            <Label Text="✿" Style="{StaticResource NavIcon}"/>
                            <Label Text="Projects" Style="{StaticResource NavText}"/>
                        </HorizontalStackLayout>
                    </Border>

                    <Label Text="REPORTS" Style="{StaticResource NavSectionHeader}"/>

                    <Border Style="{StaticResource NavRow}"
                            BackgroundColor="{Binding CurrentRoute, Converter={StaticResource NavSelectedConverter}, ConverterParameter=stocktracker}">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding NavigateCommand}" CommandParameter="stocktracker"/>
                        </Border.GestureRecognizers>
                        <HorizontalStackLayout Spacing="8">
                            <Label Text="◐" Style="{StaticResource NavIcon}"/>
                            <Label Text="Stock Tracker" Style="{StaticResource NavText}"/>
                        </HorizontalStackLayout>
                    </Border>

                    <Border Style="{StaticResource NavRow}"
                            BackgroundColor="{Binding CurrentRoute, Converter={StaticResource NavSelectedConverter}, ConverterParameter=expense}">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding NavigateCommand}" CommandParameter="expense"/>
                        </Border.GestureRecognizers>
                        <HorizontalStackLayout Spacing="8">
                            <Label Text="$" Style="{StaticResource NavIcon}"/>
                            <Label Text="Expense Report" Style="{StaticResource NavText}"/>
                        </HorizontalStackLayout>
                    </Border>

                    <Border Style="{StaticResource NavRow}"
                            BackgroundColor="{Binding CurrentRoute, Converter={StaticResource NavSelectedConverter}, ConverterParameter=sales}">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding NavigateCommand}" CommandParameter="sales"/>
                        </Border.GestureRecognizers>
                        <HorizontalStackLayout Spacing="8">
                            <Label Text="↗" Style="{StaticResource NavIcon}"/>
                            <Label Text="Sales Report" Style="{StaticResource NavText}"/>
                        </HorizontalStackLayout>
                    </Border>

                </VerticalStackLayout>
            </ScrollView>

            <!-- Bottom pinned -->
            <VerticalStackLayout Grid.Row="2" Spacing="0" Margin="0,6,0,0">
                <Border Style="{StaticResource NavRow}" BackgroundColor="Transparent">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding OpenKoFiCommand}"/>
                    </Border.GestureRecognizers>
                    <HorizontalStackLayout Spacing="8">
                        <Label Text="☕" Style="{StaticResource NavIcon}"/>
                        <Label Text="Support on Ko-fi" FontSize="13" TextColor="{StaticResource StashText}" VerticalOptions="Center"/>
                    </HorizontalStackLayout>
                </Border>
                <Border Style="{StaticResource NavRow}"
                        BackgroundColor="{Binding CurrentRoute, Converter={StaticResource NavSelectedConverter}, ConverterParameter=settings}">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding NavigateCommand}" CommandParameter="settings"/>
                    </Border.GestureRecognizers>
                    <HorizontalStackLayout Spacing="8">
                        <Label Text="⚙" Style="{StaticResource NavIcon}"/>
                        <Label Text="Settings" FontSize="13" TextColor="{StaticResource StashText}" VerticalOptions="Center"/>
                    </HorizontalStackLayout>
                </Border>
                <Border Style="{StaticResource NavRow}"
                        BackgroundColor="{Binding CurrentRoute, Converter={StaticResource NavSelectedConverter}, ConverterParameter=about}">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding NavigateCommand}" CommandParameter="about"/>
                    </Border.GestureRecognizers>
                    <HorizontalStackLayout Spacing="8">
                        <Label Text="ⓘ" Style="{StaticResource NavIcon}"/>
                        <Label Text="About" FontSize="13" TextColor="{StaticResource StashText}" VerticalOptions="Center"/>
                    </HorizontalStackLayout>
                </Border>
            </VerticalStackLayout>
        </Grid>

        <!-- ── Content pane (swapped by AppNavigator) ── -->
        <ContentView x:Name="Host" Grid.Column="1" BackgroundColor="{StaticResource StashBackground}"/>

    </Grid>
</ContentPage>
